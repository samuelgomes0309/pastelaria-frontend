# ==============================================
# Variáveis de Ambiente - Frontend Pastelaria
# ==============================================

# -----------------------------------------------
# URLs da API Backend
# -----------------------------------------------

# URL da API para chamadas do lado do cliente (navegador)
# Esta variável é PÚBLICA e fica exposta no bundle do JavaScript
# Use NEXT_PUBLIC_ para variáveis que precisam ser acessadas no navegador
# Exemplo de produção: https://api.pastelaria.com
NEXT_PUBLIC_API_URL=http://localhost:3333

# URL da API para chamadas do lado do servidor (Server Components/Actions)
# Esta variável é PRIVADA e NÃO fica exposta no bundle do JavaScript
# Use para requisições server-side que podem conter informações sensíveis
# Em produção, pode ser diferente da URL pública (ex: URL interna)
API_URL=http://localhost:3333